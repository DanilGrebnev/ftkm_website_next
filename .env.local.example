FRONTEND_PORT=3000

# DOCKER_APP_IMAGE=next_app:latest

MONGO_IMAGE=mongo:7
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin
MONGO_PORT=27017
MONGO_AUTH_DB=admin

MONGO_DB_HOST=localhost
MONGO_DB_PORT=27017

# Next.js использует только готовую строку MONGODB_URI (без подстановки ${...} из .env).
# Пример для Mongo на localhost с учётными данными выше:
MONGODB_URI=mongodb://admin:admin@localhost:27017/admin

SECRET_JWT=your-secret-key-here

ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123
