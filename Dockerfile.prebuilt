# Образ только для уже собранного Next.js (на хосте: yarn install && yarn build).
# Сборка: docker build -f Dockerfile.prebuilt -t next_app:latest .

FROM node:20-alpine AS runner
WORKDIR /app

RUN apk add --no-cache libc6-compat

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile --production

COPY public ./public
COPY .next ./.next

EXPOSE 3000

CMD ["yarn", "start"]
