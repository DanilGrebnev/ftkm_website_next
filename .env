# Next.js (порт хоста и процесса; в контейнере дублируется в PORT)
FRONTEND_PORT=8090

# Docker Compose — публикация порта Mongo на хост
MONGO_IMAGE=mongo:7
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin
MONGO_PORT=27017

MONGO_AUTH_DB=admin

# Хост и порт сервера Mongo для Mongoose (локально — localhost + порт ниже; в Docker compose переопределяется MONGO_DB_HOST=mongodb)
MONGO_DB_HOST=localhost
MONGO_DB_PORT=27017

# Плейсхолдеры ${…} раскрываются в src/shared/server_actions/db.ts (dotenv сами ${} не подставляет)
MONGODB_URI=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@${MONGO_DB_HOST}:${MONGO_DB_PORT}/${MONGO_AUTH_DB}

SECRET_JWT=your-secret-key-change-me

ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123
